generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ─────────────────────────────────────────────────────────────────────
model User {
  id            String         @id @default(cuid())
  username      String         @unique
  full_name     String
  role          Role
  password_hash String
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  approvals     Approval[]
  shifts        ShiftReport[]  @relation("ShiftOpener")
  special_logs  SpecialLog[]
  notifications Notification[]

  @@map("users")
}

// ─── SHIFT REPORT ─────────────────────────────────────────────────────────────
// id tidak lagi CUID — generate manual di application layer
// format: SHF-YYYYMMDD-S1-001
model ShiftReport {
  id                String            @id
  shift_date        DateTime          @db.Date
  opened_by         String
  opened_at         DateTime          @default(now())
  closed_at         DateTime?
  modal_awal        Decimal           @default(1000000) @db.Decimal(15, 2)
  status            ShiftStatus       @default(OPEN)
  shift_period      ShiftPeriod       @default(SHIFT_1)
  variance_note     String?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  approvals         Approval[]
  opener            User              @relation("ShiftOpener", fields: [opened_by], references: [id])
  special_logs      SpecialLog[]
  transaction_lines TransactionLine[]

  @@index([opened_by, status])
  @@index([shift_date])
  @@index([opened_by, opened_at(sort: Desc)])
  @@map("shift_reports")
}

// ─── TRANSACTION LINE ─────────────────────────────────────────────────────────
model TransactionLine {
  id         String            @id @default(cuid())
  shift_id   String
  sumber     TransactionSource
  kategori   PaymentCategory
  nilai      Decimal           @db.Decimal(15, 2)
  catatan    String?
  created_at DateTime          @default(now())
  shift      ShiftReport       @relation(fields: [shift_id], references: [id], onDelete: Cascade)

  @@index([shift_id])
  @@map("transaction_lines")
}

// ─── SPECIAL LOG ──────────────────────────────────────────────────────────────
// DEPOSIT dihapus dari tipe ini — sudah masuk TransactionLine (DEPOSIT_BANK / DEPOSIT_CASH)
model SpecialLog {
  id             String         @id @default(cuid())
  shift_id       String
  tipe           SpecialLogType
  nomor_bill     String?
  kategori_biaya String?
  nominal        Decimal        @db.Decimal(15, 2)
  keterangan     String?
  alasan         String?
  created_by     String
  created_at     DateTime       @default(now())
  creator        User           @relation(fields: [created_by], references: [id])
  shift          ShiftReport    @relation(fields: [shift_id], references: [id], onDelete: Cascade)

  @@index([shift_id])
  @@index([created_by])
  @@map("special_logs")
}

// ─── APPROVAL ─────────────────────────────────────────────────────────────────
model Approval {
  id          String         @id @default(cuid())
  shift_id    String
  approver_id String
  action      ApprovalAction
  catatan     String?
  timestamp   DateTime       @default(now())
  approver    User           @relation(fields: [approver_id], references: [id])
  shift       ShiftReport    @relation(fields: [shift_id], references: [id], onDelete: Cascade)

  @@index([shift_id])
  @@index([approver_id])
  @@map("approvals")
}

// ─── NOTIFICATION ─────────────────────────────────────────────────────────────
model Notification {
  id         String    @id @default(cuid())
  user_id    String
  type       NotifType
  shift_id   String?
  message    String
  is_read    Boolean   @default(false)
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([created_at])
  @@map("notifications")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  CASHIER
  HEAD_CASHIER
  FINANCE
}

enum ShiftStatus {
  OPEN
  PENDING
  PENDING_FINANCE
  CLOSED
}

enum TransactionSource {
  ESB
  FISIK
}

enum PaymentCategory {
  CASH
  EDC_BRI
  EDC_BNI
  EDC_BCA
  EDC_BSI
  QRIS_BRI
  QRIS_BNI
  QRIS_BCA
  QRIS_BSI
  TRANSFER_BRI
  TRANSFER_BNI
  TRANSFER_BCA
  TRANSFER_BSI
  DEPOSIT_BANK
  DEPOSIT_CASH
}

enum SpecialLogType {
  VOID
  DISCOUNT
  OTHER_COST
}

enum ApprovalAction {
  APPROVE
  REJECT
  CLOSE
}

enum ShiftPeriod {
  SHIFT_1
  SHIFT_2
}

enum NotifType {
  SHIFT_REJECTED
  SHIFT_APPROVED
  SHIFT_PENDING_REVIEW
  SHIFT_CLOSED
}
